def create_html_game():
    html = """
    <!DOCTYPE html>
    <html>
    <head>
        <title>八数码游戏</title>
        <style>
            .game-grid {
                display: grid;
                grid-template-columns: repeat(3, 100px);
                grid-gap: 10px;
            }
            .grid-item {
                width: 100px;
                height: 100px;
                background-color: #f0f0f0;
                display: flex;
                justify-content: center;
                align-items: center;
                font-size: 24px;
                border: 1px solid #ccc;
            }
            .swap-btn {
                margin-top: 10px;
            }
        </style>
    </head>
    <body>
        <div class="game-grid">
            <!-- 游戏面板将在这里生成 -->
        </div>
        <button class="swap-btn" onclick="swap()">交换</button>
        <script>
            // 游戏面板的数字
            const numbers = [1, 2, 3, 4, 5, 6, 7, 8, 0];
            // 初始化游戏面板
            function initGameGrid() {
                const grid = document.querySelector);
                numbers.forEach(num => {
                    const item = document.createElement('div');
                    item.className = 'grid-item';
                    item.textContent = num;
                    grid.appendChild(item);
                });
            }
            // 交换数字
            function swap() {
                const gridItems = document.querySelectorAll('.grid-item');
                const blankIndex = numbers.indexOf(0);
                const adjacentIndexes = [blankIndex - 1, blankIndex + 1, blankIndex - 3, blankIndex + 3];
                for (let index of adjacentIndexes) {
                    if (index >= 0 && index < numbers.length && numbers[index] !== 0) {
                        [numbers[blankIndex], numbers[index]] = [numbers[index], numbers[blankIndex]];
                        break;
                    }
                }
                gridItems.forEach((item, index) => {
                    item.textContent = numbers[index];
                });
            }
            initGameGrid();
        </script>
    </body>
    </html>
    """
    return html

html_game = create_html_game()
html_game
