{
  "name": "test_workflow_dag",
  "description": "测试工作流（nodes/edges 格式）",
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "config": {
        "input": "用户输入"
      }
    },
    {
      "id": "llm_1",
      "type": "llm",
      "config": {
