# 小雷版小龙虾Agent - 环境变量配置示例
# 复制此文件为 .env 并填写真实的API密钥

# LLM API Keys
ZHIPU_API_KEY=your_zhipu_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 第三方应用配置
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 数据库配置（可选）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=xiaolongxia_agent

# 服务器配置
PORT=8001
HOST=0.0.0.0
DEBUG=false

# Coze配置
COZE_API_TOKEN=your_coze_api_token_here
