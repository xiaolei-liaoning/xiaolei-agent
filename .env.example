# ===== LLM配置 =====
LLM_BACKEND=glm
ZHIPU_API_KEY=your_api_key_here
ZHIPU_MODEL=glm-4-flash
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# ===== 数据库配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=user_model

# ===== JWT配置 =====
JWT_SECRET_KEY=please_change_this_to_a_strong_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ===== CORS配置 =====
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ===== 功能开关 =====
USE_RAG=true
AUTO_LEARN=true

# ===== 性能调优 =====
MAX_CONCURRENT_TASKS=10
MAX_SCRAPER_CONCURRENCY=10
WORKER_POOL_SIZE=5
CIRCUIT_FAILURE_THRESHOLD=5
ENABLE_RESOURCE_MONITOR=true
MEMORY_WARNING_THRESHOLD=0.8
CPU_WARNING_THRESHOLD=0.9

# ===== 服务器配置 =====
AGENT_HOST=0.0.0.0
AGENT_PORT=8001
DEV_MODE=false
LOG_LEVEL=info
