{
  // Python配置
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  
  // 自动保存
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  
  // 格式化配置
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  
  // Black配置
  "black-formatter.args": [
    "--line-length=88"
  ],
  
  // isort配置
  "isort.args": [
    "--profile=black",
    "--line-length=88"
  ],
  
  // 文件排除
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true
  },
  
  // 搜索排除
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/.git": true
  },
  
  // GitLens增强
  "gitlens.currentLine.enabled": true,
  "gitlens.hovers.currentLine.over": "line",
  
  // TODO高亮
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "iconColour": "#ffcc00"
    },
    "FIXME": {
      "icon": "bug",
      "iconColour": "#ff6666"
    },
    "HACK": {
      "icon": "tools",
      "iconColour": "#66ccff"
    }
  },
  "Codegeex.RepoIndex": true,
  "cmake.sourceDirectory": "/Users/leiyuxuan/Desktop/小雷版agent/herdr/vendor/libghostty-vt",

  // cSpell 拼写检查 - 项目专有名词白名单
  "cSpell.words": [
    "fromlist",
    "jieba",
    "monokai",
    "osascript",
    "wechat",
    "xiaolei"
  ]
}
